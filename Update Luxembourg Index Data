name: Update Luxembourg Index Data

on:
  schedule:
    - cron: '0 8 * * 1-5'      # jeden Werktag um 8 Uhr morgens
  workflow_dispatch:           # manuell auslösbar

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install dependencies
        run: pip install pandas xlrd requests

      - name: Download & parse STATEC data
        run: python update.py

      - name: Commit & push changes
        run: |
          git config user.name "GitHub Actions"
          git config user.email "actions@github.com"
          git add data.json
          git commit -m "Update STATEC index data $(date -u +'%Y-%m-%d %H:%M UTC')" || echo "No changes"
          git push
